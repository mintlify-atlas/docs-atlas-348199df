  "keyFeatures": [
    "Six dedicated REST clients: CBAdvancedTradeClient, CBAppClient, CBExchangeClient, CBInternationalClient, CBPrimeClient, CBCommerceClient",
    "Unified WebsocketClient covering all Coinbase WebSocket feeds with auto-reconnect and resubscription",
    "Full TypeScript support with strongly-typed request and response types",
    "Supports both ECDSA and ED25519 API key formats with automatic detection",
    "JWT-based authentication for Advanced Trade & App APIs; passphrase-based for Exchange, International & Prime",
    "Sandbox/testnet support for Exchange and International APIs",
    "ESM and CJS dual-module output; browser bundle via webpack",
    "Proxy support via axios integration",
    "Customisable logging with DefaultLogger override pattern",
    "Bundled llms.txt for AI/LLM-assisted development"
  ],
  "publicApiSurface": [
    "CBAdvancedTradeClient",
    "CBAppClient",
    "CBExchangeClient",
    "CBInternationalClient",
    "CBPrimeClient",
    "CBCommerceClient",
    "WebsocketClient",
    "WS_KEY_MAP",
    "WsKey",
    "RestClientOptions",
    "DefaultLogger",
    "WsTopicRequest",
    "WSConnectedResult"
  ]
